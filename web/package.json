{
  "name": "hn-station",
  "appId": "com.hnstation.app",
  "productName": "HN Station",
  "private": true,
  "version": "1.1.0",
  "description": "Hacker News Desktop Reader",
  "author": {
    "name": "HN Station",
    "email": "noreply@hnstation.app"
  },
  "homepage": "https://github.com/rajeshkumarblr/hn_station",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build && electron-builder",
    "build:win": "tsc -b && vite build && electron-builder --win",
    "build:dir": "tsc -b && vite build && electron-builder --win --dir",
    "build:linux": "tsc -b && vite build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.hnstation.app",
    "productName": "HN Station",
    "copyright": "Copyright © 2025",
    "icon": "public/hn_256.png",
    "asar": true,
    "extraResources": [
      {
        "from": "resources/hn-local",
        "to": "hn-local",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/hn-local.exe",
        "to": "hn-local.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/hn.ico",
      "executableName": "HN Station"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HN Station",
      "menuCategory": "HN Station",
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/hn_256.png",
      "category": "News",
      "executableName": "hn-station",
      "desktop": {
        "entry": {
          "Comment": "Hacker News Desktop Reader",
          "Categories": "News;Network;"
        }
      }
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/hn_256.png",
      "category": "public.app-category.news"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "esbuild": "^0.27.3",
    "github-markdown-css": "^5.9.0",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "react-router-dom": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}